<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FBF5EE">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarChat"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#C8641C"
        android:elevation="6dp"
        app:titleTextColor="#FFFFFF"
        app:subtitleTextColor="#F2C49A"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#FFFFFF" />

    <!-- Context banner (shown when launched from a restaurant) -->
    <TextView
        android:id="@+id/tvRestaurantContext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_context_pill"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Viewing: Spice Garden · Indian cuisine"
        android:textSize="12sp"
        android:textColor="#7A3010"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:clipToPadding="false" />

    <!-- Thin divider above input -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EDD9C8" />

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:hint="Ask about food, hours, cuisine…"
            android:textColor="#1A1A1A"
            android:textColorHint="#AAAAAA"
            android:textSize="13sp"
            android:background="@drawable/bg_chat_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginEnd="10dp" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_send_button"
            android:src="@drawable/ic_send"
            app:tint="#FFFFFF"
            android:contentDescription="Send message" />

    </LinearLayout>

</LinearLayout>
